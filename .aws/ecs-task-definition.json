{
  "family": "igs-frontend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "volumes": [
    {
      "name": "tmp",
      "dockerVolumeConfiguration": {
        "scope": "task",
        "driver": "local",
        "driverOpts": {
          "type": "tmpfs",
          "device": "tmpfs",
          "o": "size=64m,uid=1001,gid=1001"
        }
      }
    },
    {
      "name": "next-cache",
      "dockerVolumeConfiguration": {
        "scope": "task",
        "driver": "local",
        "driverOpts": {
          "type": "tmpfs",
          "device": "tmpfs",
          "o": "size=256m,uid=1001,gid=1001"
        }
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "REGISTRY/igs_frontend:LATEST",
      "essential": true,
      "user": "1001:1001",
      "readonlyRootFilesystem": true,
      "stopTimeout": 60,
      "linuxParameters": {
        "initProcessEnabled": false,
        "capabilities": {
          "drop": ["ALL"]
        }
      },
      "dockerSecurityOptions": ["no-new-privileges:true"],
      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 4096,
          "hardLimit": 8192
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "tmp",
          "containerPath": "/tmp"
        },
        {
          "sourceVolume": "next-cache",
          "containerPath": "/app/.next/cache"
        }
      ],
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "NEXT_TELEMETRY_DISABLED",
          "value": "1"
        },
        {
          "name": "OTEL_EXPORTER_OTLP_ENDPOINT",
          "value": "http://localhost:4318"
        }
      ],
      "secrets": [
        {
          "name": "REDIS_HOST",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:igs/redis-host"
        },
        {
          "name": "API_BASE_URL",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:igs/api-base-url"
        },
        {
          "name": "PUBLIC_ORIGIN",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:igs/public-origin"
        },
        {
          "name": "CLIENT_ID",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:igs/client-id"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -q -O- http://127.0.0.1:3000/api/health 2>/dev/null | grep -q '\"status\":\"ok\"' || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/igs-frontend",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs"
        }
      }
    },
    {
      "name": "adot-collector",
      "image": "public.ecr.aws/aws-observability/aws-otel-collector:v0.41.0",
      "essential": false,
      "cpu": 256,
      "memoryReservation": 256,
      "memory": 384,
      "user": "1001:1001",
      "readonlyRootFilesystem": true,
      "stopTimeout": 60,
      "linuxParameters": {
        "initProcessEnabled": false,
        "capabilities": {
          "drop": ["ALL"]
        }
      },
      "dockerSecurityOptions": ["no-new-privileges:true"],
      "command": [
        "--config=/etc/ecs/ecs-default-config.yaml"
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -q -O- http://127.0.0.1:13133/ 2>/dev/null || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/igs-frontend",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "adot"
        }
      }
    }
  ],
  "tags": [
    {
      "key": "Project",
      "value": "PlayerLedger"
    },
    {
      "key": "Component",
      "value": "Frontend"
    }
  ]
}
