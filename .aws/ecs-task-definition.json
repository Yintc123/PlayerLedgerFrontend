{
  "family": "igs-frontend",
  "executionRoleArn": "arn:aws:iam::ACCOUNT:role/jko_ecs",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "volumes": [
    { "name": "tmp" },
    { "name": "next-cache" }
  ],
  "containerDefinitions": [
    {
      "name": "frontend",
      "image": "REGISTRY/igs_frontend:LATEST",
      "essential": true,
      "user": "1001:1001",
      "readonlyRootFilesystem": true,
      "stopTimeout": 60,
      "linuxParameters": {
        "initProcessEnabled": false,
        "capabilities": {
          "drop": ["ALL"]
        }
      },
      "dockerSecurityOptions": ["no-new-privileges:true"],
      "ulimits": [
        {
          "name": "nofile",
          "softLimit": 4096,
          "hardLimit": 8192
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "tmp",
          "containerPath": "/tmp"
        },
        {
          "sourceVolume": "next-cache",
          "containerPath": "/app/.next/cache"
        }
      ],
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "NEXT_TELEMETRY_DISABLED",
          "value": "1"
        },
        {
          "name": "OTEL_SDK_DISABLED",
          "value": "true"
        },
        {
          "name": "REDIS_HOST",
          "value": "EC2_PRIVATE_IP"
        },
        {
          "name": "API_BASE_URL",
          "value": "https://httpbin.org"
        },
        {
          "name": "PUBLIC_ORIGIN",
          "value": "http://igs-frontend-alb-1031231573.ap-southeast-2.elb.amazonaws.com"
        },
        {
          "name": "CLIENT_ID",
          "value": "cms-web"
        }
      ],
      "secrets": [
        {
          "name": "REDIS_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:REDIS_PASSWORD"
        }
      ],
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget -q -O- http://127.0.0.1:3000/api/health 2>/dev/null | grep -q '\"status\":\"ok\"' || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      },
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/igs-frontend",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ],
  "tags": [
    {
      "key": "Project",
      "value": "PlayerLedger"
    },
    {
      "key": "Component",
      "value": "Frontend"
    }
  ]
}
