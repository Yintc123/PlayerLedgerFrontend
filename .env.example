# =============================================================
# PlayerLedger Frontend — 環境變數範例
# 複製此檔案為 .env 並填入實際值，.env 不得提交至版本控制
# =============================================================

# -------------------------------------------------------------
# Redis（REDIS_HOST 必填，其餘選填）
# 本地開發：REDIS_HOST=localhost
# ElastiCache（production）：REDIS_HOST=your-cluster.cache.amazonaws.com
# -------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -------------------------------------------------------------
# Go API Server（API_BASE_URL 必填，API_TIMEOUT_MS 選填）
# 本地開發：http://localhost:8080
# API_TIMEOUT_MS：上游 fetch 主動 timeout，預設 20000（20s，對齊 §12.1 API Gateway 29s 上限）
#   ⚠️  不可大於 25000——超過會被 API Gateway 直接砍而非走 BFF 自己的 timeout 路徑
# -------------------------------------------------------------
API_BASE_URL=http://localhost:8080
# API_TIMEOUT_MS=20000

# -------------------------------------------------------------
# Client ID（必填）
# 對應後端 JWT_CLIENT_POLICIES 的 key，決定 refresh / absolute TTL 政策
# 後端 ADR 007 定義：
#   cms-web      → refresh 1h / abs_exp 8h（CMS 後台）
#   public-web   → refresh 1h / abs_exp 24h（一般使用者 web）
#   ios-app      → refresh 30d / abs_exp 180d
#   android-app  → refresh 30d / abs_exp 180d
# 本 BFF 預設服務 CMS：CLIENT_ID=cms-web
# -------------------------------------------------------------
CLIENT_ID=cms-web

# -------------------------------------------------------------
# Session 行為（選填）
# SESSION_TTL_SECONDS：BFF session 最長閒置時間上限，採滑動過期
#   實際 TTL = min(SESSION_TTL_SECONDS, absoluteExpiresAt - now)
#   預設 28800（8 小時，對齊 cms-web abs_exp）
#   ⚠️  若 CLIENT_ID 改為 abs_exp 較長的 client（public-web 24h / mobile 180d），需同步調整
# REFRESH_THRESHOLD_SECONDS：access token 距到期剩餘秒數低於此值時觸發 refresh
#   ⚠️  後端 access token 有效期為 15 分鐘（900s，見後端 ADR 007），
#   threshold 須遠小於此值（建議 ≤ 1/4，即 ≤ 225s），預設 180s（3 分鐘）
#   若後端調整 token 有效期，需同步評估此設定
# REFRESH_LOCK_TTL_SECONDS：Redis mutex 最長持鎖時間（安全網，防 crash 永久卡鎖）
# -------------------------------------------------------------
# SESSION_TTL_SECONDS=28800
# REFRESH_THRESHOLD_SECONDS=180
# REFRESH_LOCK_TTL_SECONDS=10

# -------------------------------------------------------------
# CSRF 防護：允許的 Origin（必填一個 PUBLIC_ORIGIN）
# 詳見 ADR 013 - CSRF Defense Strategy
# PUBLIC_ORIGIN：BFF 對外服務的完整 origin（scheme + hostname + port）
#   開發環境：PUBLIC_ORIGIN=http://localhost:3000
#   生產環境：PUBLIC_ORIGIN=https://playerledger.com
# ALLOWED_ORIGINS_EXTRA：額外允許的 origin（逗號分隔，選填）
#   ⚠️  production 應留空；只在開發或特殊整合場景使用
# -------------------------------------------------------------
PUBLIC_ORIGIN=http://localhost:3000
# ALLOWED_ORIGINS_EXTRA=

# -------------------------------------------------------------
# Cookie（選填）
# COOKIE_DOMAIN：預設留空（Host-only cookie，最安全）
#   ⚠️  禁止設為 .playerledger.com 等通配形式——任一子網域 XSS 即洩漏 sid
#   只在「需要跨子網域共享 session」時才設定，且必須具體（如 app.playerledger.com）
# NODE_ENV：Next.js 會自動設定（development / production），
#   production 時 Cookie 強制帶 Secure flag
# -------------------------------------------------------------
# COOKIE_DOMAIN=
